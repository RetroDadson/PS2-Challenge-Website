{
  "name": "ps2-challenge-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "node scripts-ts/dev.mjs",
    "dev:server": "npm run dev -w @ps2-challenge/server",
    "dev:client": "npm run dev -w @ps2-challenge/client",
    "build": "npm run build -w @ps2-challenge/shared && npm run build -w @ps2-challenge/client && npm run build -w @ps2-challenge/server",
    "lint": "npm run lint --workspaces && eslint tests --ext .ts",
    "typecheck": "npm run build -w @ps2-challenge/shared && npm run typecheck -w @ps2-challenge/client && npm run typecheck -w @ps2-challenge/server && npm run typecheck -w @ps2-challenge/shared && tsc -p tsconfig.scripts.json --noEmit && tsc -p tests/e2e/tsconfig.json --noEmit",
    "test": "npm run build -w @ps2-challenge/shared && npm run test --workspaces --if-present",
    "coverage": "npm run build -w @ps2-challenge/shared && npm run coverage --workspaces --if-present",
    "test:integration": "npm run test:integration -w @ps2-challenge/server",
    "test:e2e": "npm run build -w @ps2-challenge/shared && playwright test -c tests/e2e/playwright.config.ts",
    "migrate": "npm run migrate -w @ps2-challenge/server",
    "start": "npm run start -w @ps2-challenge/server",
    "import:serials": "tsx scripts-ts/import-serial-numbers.ts",
    "import:alternate-titles": "tsx scripts-ts/import-alternate-titles.ts",
    "import:wiki-serials": "tsx scripts-ts/import-wiki-serials.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testcontainers/postgresql": "^12.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@azure/monitor-opentelemetry": "^1.18.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "@opentelemetry/api": "^1.9.1",
    "chart.js": "^4.5.1",
    "fastify": "^5.8.5",
    "kysely": "^0.29.2",
    "lucide-react": "^1.21.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@opentelemetry/api-logs": "0.219.0",
    "@opentelemetry/configuration": "0.219.0",
    "@opentelemetry/context-async-hooks": "2.8.0",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-logs-otlp-http": "0.219.0",
    "@opentelemetry/exporter-logs-otlp-proto": "0.219.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.219.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.219.0",
    "@opentelemetry/exporter-prometheus": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.219.0",
    "@opentelemetry/exporter-zipkin": "2.8.0",
    "@opentelemetry/instrumentation": "0.219.0",
    "@opentelemetry/instrumentation-bunyan": "0.64.0",
    "@opentelemetry/instrumentation-http": "0.219.0",
    "@opentelemetry/instrumentation-mongodb": "0.72.0",
    "@opentelemetry/instrumentation-mysql": "0.65.0",
    "@opentelemetry/instrumentation-pg": "0.71.0",
    "@opentelemetry/instrumentation-redis": "0.67.0",
    "@opentelemetry/instrumentation-winston": "0.63.0",
    "@opentelemetry/otlp-exporter-base": "0.219.0",
    "@opentelemetry/otlp-grpc-exporter-base": "0.219.0",
    "@opentelemetry/otlp-transformer": {
      ".": "0.219.0",
      "protobufjs": "8.6.4"
    },
    "@opentelemetry/propagator-b3": "2.8.0",
    "@opentelemetry/propagator-jaeger": "2.8.0",
    "@opentelemetry/resource-detector-azure": "0.27.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-logs": "0.219.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@opentelemetry/sdk-trace-node": "2.8.0",
    "@opentelemetry/sdk-trace-web": "2.8.0",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@opentelemetry/sql-common": "0.42.0",
    "@opentelemetry/winston-transport": "0.29.0",
    "ws": "8.21.0"
  }
}
