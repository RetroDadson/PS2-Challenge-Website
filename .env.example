# PS2 Challenge - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# GitHub Container Registry
# ============================================================================
# Your GitHub username (for pulling Docker images)
GITHUB_USERNAME=yourusername

# Docker image tag to use (latest, master, specific commit hash, etc.)
IMAGE_TAG=latest

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL password (change this in production!)
DB_PASSWORD=changeme

# ============================================================================
# Twitch OAuth Configuration
# ============================================================================
# Get these from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# ============================================================================
# Admin API Key / Cookie Secret Fallback
# ============================================================================
# Existing users authenticate API requests with generated per-user API keys.
# ADMIN_API_KEY remains as a deployment secret and fallback cookie signing secret.
ADMIN_API_KEY=your_secure_admin_api_key_here
COOKIE_SECRET=your_secure_cookie_secret_here

# ============================================================================
# Application Configuration
# ============================================================================
# Environment: Development, Staging, or Production
NODE_ENV=Production
PORT=5001
PUBLIC_BASE_URL=http://localhost:5001

# Logging level: trace, debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# Development Tools (for docker/docker-compose.dev.yml)
# ============================================================================
# pgAdmin credentials
PGADMIN_EMAIL=admin@ps2challenge.local
PGADMIN_PASSWORD=admin

# ============================================================================
# Optional: External Services
# ============================================================================
# If using external PostgreSQL, override the connection string
# DATABASE_CONNECTION_STRING=Host=external-host;Port=5432;Database=ps2challenge;Username=user;Password=pass

# ============================================================================
# Nginx Configuration (if using reverse proxy)
# ============================================================================
# Domain name for your application
# DOMAIN_NAME=ps2challenge.example.com

# SSL certificate paths
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
