# Database Configuration
PS2_CHALLENGE_CONNECTION_STRING=Host=localhost;Database=dadsons_ps2_challenge;Username=ps2_challenge;Password=SuperSecurePassword123

# JWT Configuration (for future authentication)
PS2_CHALLENGE_JWT_SECRET=your-super-secret-jwt-key-here
PS2_CHALLENGE_JWT_EXPIRATION_MINUTES=60

# CORS Configuration
PS2_CHALLENGE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
PS2_CHALLENGE_LOG_LEVEL=Information

# Swagger
PS2_CHALLENGE_ENABLE_SWAGGER=true

# URLs
PS2_CHALLENGE_API_BASE_URL=http://localhost:5000
PS2_CHALLENGE_FRONTEND_URL=http://localhost:3000
