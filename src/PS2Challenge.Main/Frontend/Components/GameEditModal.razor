@using PS2Challenge.Backend.Models
@using PS2Challenge.Backend.Services
@using PS2Challenge.Backend.Data.Repositories
@using Microsoft.EntityFrameworkCore
@using PS2Challenge.Backend.Data
@using System.Net.Http.Json
@using Microsoft.AspNetCore.SignalR
@using PS2Challenge.Main.Api.Hubs
@inject IJSRuntime JSRuntime
@inject IServiceScopeFactory ScopeFactory
@inject GameService GameService
@inject HttpClient HttpClient
@inject IHubContext<GamesHub> HubContext

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="HandleOverlayClick">
        <div class="modal-content game-edit-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>@(IsEditMode ? $"Edit Game: {Game?.Title}" : "Add New Game")</h2>
                <button class="modal-close" @onclick="Close">&times;</button>
            </div>
            
            <div class="modal-body">
                @if (errorMessage != null)
                {
                    <div class="alert alert-error">
                        @errorMessage
                    </div>
                }

                <div class="form-container">
                    <div class="form-field">
                        <label>Title *</label>
                        <input type="text" @bind="internalTitle" class="search-input" maxlength="150" />
                    </div>

                    <div class="form-row">
                        <div class="form-field">
                            <label>Developer *</label>
                            <input type="text" @bind="internalDeveloper" class="search-input" maxlength="100" />
                        </div>

                        <div class="form-field">
                            <label>Publisher *</label>
                            <input type="text" @bind="internalPublisher" class="search-input" maxlength="100" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-field">
                            <label>First Released</label>
                            <input type="date" @bind="internalFirstReleased" class="search-input" />
                        </div>

                        <div class="form-field">
                            <label>Region First Released *</label>
                            <input type="text" @bind="internalRegion" class="search-input" maxlength="100" placeholder="e.g., NA, EU, JP" />
                        </div>
                    </div>

                    <div class="form-field">
                        <label>
                            <input type="checkbox" @bind="internalReleasedInEuPalOrNa" />
                            Released in EU/PAL or NA
                        </label>
                    </div>

                    <hr class="section-divider" />

                    <h3>Serial Numbers</h3>
                    <div class="serial-numbers-section">
                        @if (isLoadingData)
                        {
                            <div class="loading-container">
                                <p>Loading serial numbers...</p>
                            </div>
                        }
                        else if (serialNumbers.Any())
                        {
                            <div class="serial-numbers-list">
                                @foreach (var serial in serialNumbers.Where(s => !s.IsDeleted))
                                {
                                    <div class="serial-number-item">
                                        <div class="serial-number-display">
                                            <span class="serial-code"><strong>@serial.SerialNumber</strong></span>
                                            @if (!string.IsNullOrWhiteSpace(serial.Region))
                                            {
                                                <span class="serial-region badge">@serial.Region</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(serial.Notes))
                                            {
                                                <span class="serial-notes">@serial.Notes</span>
                                            }
                                        </div>
                                        <button type="button" class="btn-icon btn-remove" @onclick="() => RemoveSerialNumber(serial)" title="Remove">×</button>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="no-data-message">No serial numbers added yet.</p>
                        }

                        <div class="add-serial-number-form">
                            <div class="form-row">
                                <div class="form-field">
                                    <label>Serial Number</label>
                                    <input type="text" @bind="newSerialNumber" class="search-input" maxlength="50" placeholder="e.g., SLUS-20062" />
                                </div>
                                <div class="form-field">
                                    <label>Region</label>
                                    <input type="text" @bind="newSerialRegion" class="search-input" maxlength="50" placeholder="e.g., NTSC-U, PAL" />
                                </div>
                            </div>
                            <div class="form-field">
                                <label>Notes (Optional)</label>
                                <input type="text" @bind="newSerialNotes" class="search-input" maxlength="500" placeholder="e.g., North American release" />
                            </div>
                            <button type="button" class="btn btn-secondary" @onclick="AddSerialNumber" disabled="@(string.IsNullOrWhiteSpace(newSerialNumber))">
                                + Add Serial Number
                            </button>
                        </div>
                    </div>

                    <hr class="section-divider" />

                    <h3>Alternate Titles</h3>
                    <div class="alternate-titles-section">
                        @if (isLoadingData)
                        {
                            <div class="loading-container">
                                <p>Loading alternate titles...</p>
                            </div>
                        }
                        else if (alternateTitles.Any())
                        {
                            <div class="alternate-titles-list">
                                @foreach (var title in alternateTitles.Where(t => !t.IsDeleted))
                                {
                                    <div class="alternate-title-item">
                                        <div class="alternate-title-display">
                                            <span class="alternate-title-text"><strong>@title.Title</strong></span>
                                            @if (!string.IsNullOrWhiteSpace(title.Notes))
                                            {
                                                <span class="alternate-notes">@title.Notes</span>
                                            }
                                        </div>
                                        <button type="button" class="btn-icon btn-remove" @onclick="() => RemoveAlternateTitle(title)" title="Remove">×</button>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="no-data-message">No alternate titles added yet.</p>
                        }

                        <div class="add-alternate-title-form">
                            <div class="form-field">
                                <label>Alternate Title</label>
                                <input type="text" @bind="newAlternateTitle" class="search-input" maxlength="150" placeholder="e.g., Ratchet & Clank 2" />
                            </div>
                            <div class="form-field">
                                <label>Notes (Optional)</label>
                                <input type="text" @bind="newAlternateTitleNotes" class="search-input" maxlength="500" placeholder="e.g., European release title" />
                            </div>
                            <button type="button" class="btn btn-secondary" @onclick="AddAlternateTitle" disabled="@(string.IsNullOrWhiteSpace(newAlternateTitle))">
                                + Add Alternate Title
                            </button>
                        </div>
                    </div>

                    <hr class="section-divider" />

                    <h3>Ownership Status</h3>
                    <div class="form-field">
                        <label>
                            <input type="checkbox" @bind="internalOwnPhysicalCopy" />
                            Own Physical Copy
                        </label>
                    </div>

                    <div class="form-field">
                        <label>Type Owned</label>
                        @if (ownershipTypes.Any())
                        {
                            <select @bind="internalTypeOwned" class="search-input" disabled="@(!internalOwnPhysicalCopy)">
                                <option value="">-- Select Type --</option>
                                @foreach (var type in ownershipTypes)
                                {
                                    <option value="@type.TypeOwned">@type.TypeOwned</option>
                                }
                            </select>
                        }
                        else
                        {
                            <!-- Allow free text editing while types are loading or when none are defined. Disabled until Own Physical Copy is checked. -->
                            <input type="text" @bind="internalTypeOwned" class="search-input" placeholder="Loading types..." disabled="@(!internalOwnPhysicalCopy)" />
                        }
                    </div>

                    <hr class="section-divider" />

                    <h3>Exclusion Status</h3>
                    <div class="form-field">
                        <label>
                            <input type="checkbox" @bind="internalIsExcluded" />
                            Exclude from Challenge
                        </label>
                    </div>

                    @if (internalIsExcluded)
                    {
                        <div class="form-field indent">
                            <label>Exclusion Reason *</label>
                            <textarea @bind="internalExclusionReason" class="search-input" rows="3" placeholder="Reason for exclusion..."></textarea>
                        </div>
                    }
                </div>
            </div>

            <div class="modal-footer">
                @if (IsEditMode)
                {
                    <button class="btn btn-danger" @onclick="DeleteGame" disabled="@isProcessing">Delete</button>
                }
                <button class="btn btn-secondary" @onclick="Close" disabled="@isProcessing">Cancel</button>
                <button class="cta-button" @onclick="Save" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span>Processing...</span>
                    }
                    else
                    {
                        <span>@(IsEditMode ? "Update" : "Create")</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public GameDto? Game { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }

    private string? internalTitle;
    private string? internalDeveloper;
    private string? internalPublisher;
    private DateTime? internalFirstReleased;
    private string? internalRegion;
    private bool internalReleasedInEuPalOrNa;
    private bool internalOwnPhysicalCopy;
    private string? internalTypeOwned;
    private bool internalIsExcluded;
    private string? internalExclusionReason;

    // Serial numbers management
    private List<SerialNumberEntry> serialNumbers = new();
    private string? newSerialNumber;
    private string? newSerialRegion;
    private string? newSerialNotes;

    // Alternate titles management
    private List<AlternateTitleEntry> alternateTitles = new();
    private string? newAlternateTitle;
    private string? newAlternateTitleNotes;

    private List<OwnershipType> ownershipTypes = new();
    private string? errorMessage;
    private bool isProcessing;
    private bool isLoadingData;
    
    // Track the last game ID to detect when we switch between games
    private int? lastGameId;

    // Internal class to track serial numbers (both existing and new)
    private class SerialNumberEntry
    {
        public int? SerialId { get; set; } // Null for new entries
        public required string SerialNumber { get; set; }
        public string? Region { get; set; }
        public string? Notes { get; set; }
        public bool IsDeleted { get; set; } // Track if existing entry should be deleted
    }

    // Internal class to track alternate titles (both existing and new)
    private class AlternateTitleEntry
    {
        public int? AlternateTitleId { get; set; } // Null for new entries
        public required string Title { get; set; }
        public string? Notes { get; set; }
        public bool IsDeleted { get; set; } // Track if existing entry should be deleted
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadOwnershipTypes();
    }

    private async Task LoadOwnershipTypes()
    {
        try
        {
            // Use the GameService (server-side) instead of HttpClient to match the UI design
            var types = await GameService.GetAllOwnershipTypesAsync();
            ownershipTypes = types?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading ownership types: {ex.Message}");
            ownershipTypes = new();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Ensure ownership types are available when modal opens
        if (IsVisible && !ownershipTypes.Any())
        {
            await LoadOwnershipTypes();
        }

        // When modal becomes visible, always check if we need to reload data
        if (IsVisible && Game != null)
        {
            // Detect if we're opening a different game or switching modes
            var currentGameId = Game?.Id;
            var gameChanged = currentGameId != lastGameId;
            
            // Reset state when switching between games, reopening, or opening for a new game
            if (gameChanged || currentGameId == 0)
            {
                isLoadingData = true;
                
                // Always start fresh - reset all fields first
                internalTitle = Game?.Title;
                internalDeveloper = Game?.Developer;
                internalPublisher = Game?.Publisher;
                internalFirstReleased = Game?.FirstReleased?.ToDateTime(TimeOnly.MinValue);
                internalRegion = Game?.RegionFirstReleasedIn;
                internalReleasedInEuPalOrNa = Game?.ReleasedInEuPalOrNa ?? false;
                internalIsExcluded = Game?.IsExcluded ?? false;
                
                // Always clear serial numbers and alternate titles and form for new games or when switching
                serialNumbers.Clear();
                alternateTitles.Clear();
                ClearSerialNumberForm();
                ClearAlternateTitleForm();
                
                // Reset ownership and exclusion to defaults
                internalOwnPhysicalCopy = false;
                internalTypeOwned = string.Empty;
                internalExclusionReason = string.Empty;
                
                // Load all async data before setting up the UI state
                if (IsEditMode && currentGameId > 0)
                {
                    // Load serial numbers, alternate titles, ownership, and exclusion in parallel
                    var tasks = new List<Task>
                    {
                        LoadSerialNumbers(),
                        LoadAlternateTitles(),
                        LoadCurrentOwnership()
                    };
                    
                    if (Game?.IsExcluded == true)
                    {
                        tasks.Add(LoadCurrentExclusion());
                    }

                    await Task.WhenAll(tasks);
                }
                
                isLoadingData = false;
            }
            
            // Update lastGameId after processing
            lastGameId = currentGameId;
        }
        else if (IsVisible && !IsEditMode && Game == null)
        {
            // Ensure clean state when opening for a new game with null Game object
            ResetForm();
            lastGameId = null;
        }
        else if (!IsVisible)
        {
            // Reset tracking when modal is closed
            lastGameId = null;
        }
        
        errorMessage = null;
    }

    private async Task LoadSerialNumbers()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<Ps2ChallengeDbContext>();
            
            var existingSerials = await db.GameSerialNumbers
                .AsNoTracking()
                .Where(gsn => gsn.GameId == Game!.Id)
                .ToListAsync();
            
            serialNumbers = existingSerials.Select(s => new SerialNumberEntry
            {
                SerialId = s.SerialId,
                SerialNumber = s.SerialNumber,
                Region = s.Region,
                Notes = s.Notes,
                IsDeleted = false
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading serial numbers: {ex.Message}");
            serialNumbers.Clear();
        }
    }

    private async Task LoadAlternateTitles()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<Ps2ChallengeDbContext>();
            
            var existingTitles = await db.AlternateTitles
                .AsNoTracking()
                .Where(at => at.GameId == Game!.Id)
                .ToListAsync();
            
            alternateTitles = existingTitles.Select(t => new AlternateTitleEntry
            {
                AlternateTitleId = t.AlternateTitleId,
                Title = t.Title,
                Notes = t.Notes,
                IsDeleted = false
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading alternate titles: {ex.Message}");
            alternateTitles.Clear();
        }
    }

    private void AddSerialNumber()
    {
        if (string.IsNullOrWhiteSpace(newSerialNumber))
        {
            return;
        }

        // Check for duplicates in the current list
        if (serialNumbers.Any(s => s.SerialNumber.Equals(newSerialNumber.Trim(), StringComparison.OrdinalIgnoreCase) && !s.IsDeleted))
        {
            errorMessage = $"Serial number '{newSerialNumber}' is already in the list.";
            return;
        }

        serialNumbers.Add(new SerialNumberEntry
        {
            SerialId = null, // New entry, no ID yet
            SerialNumber = newSerialNumber.Trim(),
            Region = newSerialRegion?.Trim(),
            Notes = newSerialNotes?.Trim()
        });

        ClearSerialNumberForm();
        errorMessage = null;
    }

    private void AddAlternateTitle()
    {
        if (string.IsNullOrWhiteSpace(newAlternateTitle))
        {
            return;
        }

        // Check for duplicates in the current list
        if (alternateTitles.Any(t => t.Title.Equals(newAlternateTitle.Trim(), StringComparison.OrdinalIgnoreCase) && !t.IsDeleted))
        {
            errorMessage = $"Alternate title '{newAlternateTitle}' is already in the list.";
            return;
        }

        alternateTitles.Add(new AlternateTitleEntry
        {
            AlternateTitleId = null, // New entry, no ID yet
            Title = newAlternateTitle.Trim(),
            Notes = newAlternateTitleNotes?.Trim()
        });

        ClearAlternateTitleForm();
        errorMessage = null;
    }

    private void RemoveSerialNumber(SerialNumberEntry serial)
    {
        if (serial.SerialId.HasValue)
        {
            // Existing entry - mark for deletion
            serial.IsDeleted = true;
        }
        else
        {
            // New entry - just remove from list
            serialNumbers.Remove(serial);
        }
    }

    private void RemoveAlternateTitle(AlternateTitleEntry title)
    {
        if (title.AlternateTitleId.HasValue)
        {
            // Existing entry - mark for deletion
            title.IsDeleted = true;
        }
        else
        {
            // New entry - just remove from list
            alternateTitles.Remove(title);
        }
    }

    private void ClearSerialNumberForm()
    {
        newSerialNumber = string.Empty;
        newSerialRegion = string.Empty;
        newSerialNotes = string.Empty;
    }

    private void ClearAlternateTitleForm()
    {
        newAlternateTitle = string.Empty;
        newAlternateTitleNotes = string.Empty;
    }

    private async Task LoadCurrentOwnership()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<Ps2ChallengeDbContext>();
            
            var ownership = await db.GamesOwned
                .AsNoTracking()
                .FirstOrDefaultAsync(o => o.GameId == Game!.Id);
            
            if (ownership != null)
            {
                internalOwnPhysicalCopy = ownership.OwnPhysicalCopy;
                internalTypeOwned = ownership.TypeOwned;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading ownership details: {ex.Message}");
        }
    }

    private async Task LoadCurrentExclusion()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<Ps2ChallengeDbContext>();
            
            var exclusion = await db.ExcludedGames
                .AsNoTracking()
                .FirstOrDefaultAsync(e => e.GameId == Game!.Id);
            
            if (exclusion != null)
            {
                internalExclusionReason = exclusion.Reason;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading exclusion details: {ex.Message}");
        }
    }

    private void ResetForm()
    {
        internalTitle = string.Empty;
        internalDeveloper = string.Empty;
        internalPublisher = string.Empty;
        internalFirstReleased = null;
        internalRegion = string.Empty;
        internalReleasedInEuPalOrNa = false;
        internalOwnPhysicalCopy = false;
        internalTypeOwned = string.Empty;
        internalIsExcluded = false;
        internalExclusionReason = string.Empty;
        serialNumbers.Clear();
        alternateTitles.Clear();
        ClearSerialNumberForm();
        ClearAlternateTitleForm();
        errorMessage = null;
        isLoadingData = false;
        isProcessing = false;
    }

    private async Task Close()
    {
        if (!isProcessing)
        {
            // Reset form state when closing to ensure next open is clean
            ResetForm();
            await OnClose.InvokeAsync();
        }
    }

    private async Task HandleOverlayClick()
    {
        await Close();
    }

    private async Task Save()
    {
        errorMessage = null;

        // Validation
        if (string.IsNullOrWhiteSpace(internalTitle))
        {
            errorMessage = "Title is required";
            return;
        }
        if (string.IsNullOrWhiteSpace(internalDeveloper))
        {
            errorMessage = "Developer is required";
            return;
        }
        if (string.IsNullOrWhiteSpace(internalPublisher))
        {
            errorMessage = "Publisher is required";
            return;
        }
        if (string.IsNullOrWhiteSpace(internalRegion))
        {
            errorMessage = "Region is required";
            return;
        }
        if (internalIsExcluded && string.IsNullOrWhiteSpace(internalExclusionReason))
        {
            errorMessage = "Exclusion reason is required when excluding a game";
            return;
        }

        isProcessing = true;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<Ps2ChallengeDbContext>();

            int gameId;

            if (IsEditMode && Game != null && Game.Id > 0)
            {
                // Update existing game
                var gameDto = new GameDto
                {
                    Id = Game.Id,
                    Title = internalTitle.Trim(),
                    Developer = internalDeveloper.Trim(),
                    Publisher = internalPublisher.Trim(),
                    FirstReleased = internalFirstReleased.HasValue ? DateOnly.FromDateTime(internalFirstReleased.Value) : null,
                    RegionFirstReleasedIn = internalRegion.Trim(),
                    ReleasedInEuPalOrNa = internalReleasedInEuPalOrNa
                };

                await GameService.UpdateGameAsync(Game.Id, gameDto);
                gameId = Game.Id;

                // Update ownership (service will determine if owned based on physical copy or type)
                await GameService.UpdateOwnershipAsync(Game.Id, internalOwnPhysicalCopy, internalTypeOwned ?? string.Empty);

                // Update exclusion - this might affect the total game count
                await GameService.UpdateExclusionAsync(Game.Id, internalIsExcluded, internalExclusionReason);
            }
            else
            {
                // Create new game
                var gameDto = new GameDto
                {
                    Title = internalTitle.Trim(),
                    Developer = internalDeveloper.Trim(),
                    Publisher = internalPublisher.Trim(),
                    FirstReleased = internalFirstReleased.HasValue ? DateOnly.FromDateTime(internalFirstReleased.Value) : null,
                    RegionFirstReleasedIn = internalRegion.Trim(),
                    ReleasedInEuPalOrNa = internalReleasedInEuPalOrNa
                };

                var createdGame = await GameService.AddGameAsync(gameDto);
                gameId = createdGame.Id;

                // Set ownership (service will determine if owned based on physical copy or type)
                await GameService.UpdateOwnershipAsync(createdGame.Id, internalOwnPhysicalCopy, internalTypeOwned ?? string.Empty);

                // Set exclusion if needed
                if (internalIsExcluded)
                {
                    await GameService.UpdateExclusionAsync(createdGame.Id, true, internalExclusionReason ?? "No reason provided");
                }
            }

            // Handle serial numbers
            await SaveSerialNumbers(gameId);

            // Handle alternate titles
            await SaveAlternateTitles(gameId);

            // Notify SignalR clients that game data was updated
            await HubContext.Clients.All.SendAsync("GamesUpdated");

            await OnSave.InvokeAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving game: {ex.Message}";
            Console.WriteLine($"Error in GameEditModal.Save: {ex}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task SaveSerialNumbers(int gameId)
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<Ps2ChallengeDbContext>();

        // Delete marked serial numbers
        var toDelete = serialNumbers.Where(s => s.SerialId.HasValue && s.IsDeleted).ToList();
        foreach (var serial in toDelete)
        {
            var existing = await db.GameSerialNumbers.FindAsync(serial.SerialId!.Value);
            if (existing != null)
            {
                db.GameSerialNumbers.Remove(existing);
            }
        }

        // Add new serial numbers
        var toAdd = serialNumbers.Where(s => !s.SerialId.HasValue && !s.IsDeleted).ToList();
        foreach (var serial in toAdd)
        {
            // Check if serial number already exists in database
            var duplicate = await db.GameSerialNumbers
                .FirstOrDefaultAsync(gsn => gsn.SerialNumber == serial.SerialNumber);
            
            if (duplicate != null)
            {
                var existingGame = await db.Games.FindAsync(duplicate.GameId);
                throw new InvalidOperationException(
                    $"Serial number '{serial.SerialNumber}' already exists for game '{existingGame?.Title ?? "Unknown"}' (ID: {duplicate.GameId})");
            }

            db.GameSerialNumbers.Add(new GameSerialNumber
            {
                GameId = gameId,
                SerialNumber = serial.SerialNumber,
                Region = serial.Region,
                Notes = serial.Notes
            });
        }

        await db.SaveChangesAsync();
    }

    private async Task SaveAlternateTitles(int gameId)
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<Ps2ChallengeDbContext>();

        // Delete marked alternate titles
        var toDelete = alternateTitles.Where(t => t.AlternateTitleId.HasValue && t.IsDeleted).ToList();
        foreach (var title in toDelete)
        {
            var existing = await db.AlternateTitles.FindAsync(title.AlternateTitleId!.Value);
            if (existing != null)
            {
                db.AlternateTitles.Remove(existing);
            }
        }

        // Add new alternate titles
        var toAdd = alternateTitles.Where(t => !t.AlternateTitleId.HasValue && !t.IsDeleted).ToList();
        foreach (var title in toAdd)
        {
            db.AlternateTitles.Add(new AlternateTitle
            {
                GameId = gameId,
                Title = title.Title,
                Notes = title.Notes
            });
        }

        await db.SaveChangesAsync();
    }

    private async Task DeleteGame()
    {
        if (Game == null || !IsEditMode) return;

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"Are you sure you want to delete '{Game.Title}'? This will also remove all related data (ownership, exclusions, progress, serial numbers).");

        if (confirmed)
        {
            isProcessing = true;
            try
            {
                await GameService.DeleteGameAsync(Game.Id);
                
                // Notify SignalR clients that a game was deleted
                await HubContext.Clients.All.SendAsync("GamesUpdated");
                
                await OnDelete.InvokeAsync(Game.Id);
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting game: {ex.Message}";
                Console.WriteLine($"Error in GameEditModal.DeleteGame: {ex}");
            }
            finally
            {
                isProcessing = false;
            }
        }
    }
}
