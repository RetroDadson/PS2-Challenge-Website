<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>Dadson's PS2 Challenge</title>
    <link rel="stylesheet" href="css/navmenu.css" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="icon" type="image/png" href="assets/Discord Icon.png" />
    <link href="PS2Challenge.Main.styles.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    <HeadOutlet />
</head>
<body>
    <Routes />

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">??</a>
    </div>

    <div id="components-reconnect-modal" style="position: fixed; top: 0; right: 0; bottom: 0; left: 0; z-index: 10000; background-color: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center;">
        <div style="background: var(--background-card); padding: 2rem; border-radius: 12px; max-width: 400px; text-align: center; border: 2px solid var(--primary-color);">
            <h3 style="color: var(--text-primary); margin-bottom: 1rem;">?? Connection Lost</h3>
            <p style="color: var(--text-secondary); margin-bottom: 1rem;">Attempting to reconnect...</p>
            <div class="loading" style="margin: 0 auto;"></div>
        </div>
    </div>

    <script src="_framework/blazor.web.js"></script>
    <script src="js/cover-hover.js"></script>
    <script src="js/games-filter.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8/hammer.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.min.js"></script>
    <script src="js/statistics-chart.js"></script>
    
    <script>
        // Customize Blazor reconnection UI
        Blazor.start().then(() => {
            console.log('? Blazor started successfully');
            
            const reconnectModal = document.getElementById('components-reconnect-modal');
            let reconnecting = false;
            
            // Detect when Blazor circuit is lost
            Blazor.reconnect = async () => {
                if (reconnecting) return;
                reconnecting = true;
                
                console.log('?? Blazor connection lost, showing reconnection modal');
                reconnectModal.style.display = 'flex';
                
                // FORCE activate JavaScript filters after a short delay
                setTimeout(() => {
                    if (window.gamesFilter && !window.gamesFilter.isActive) {
                        console.log('?? Force activating JavaScript filters');
                        window.gamesFilter.init();
                    }
                }, 1500);
                
                // Try to reconnect
                let attempts = 0;
                const maxAttempts = 8;
                
                while (attempts < maxAttempts) {
                    attempts++;
                    console.log(`?? Reconnection attempt ${attempts}/${maxAttempts}`);
                    
                    try {
                        await new Promise(resolve => setTimeout(resolve, attempts * 1000));
                        
                        // Check if we're back online
                        if (navigator.onLine) {
                            console.log('? Back online, reloading page');
                            window.location.reload();
                            return;
                        }
                    } catch (e) {
                        console.log(`? Reconnection attempt ${attempts} failed:`, e);
                    }
                }
                
                console.log('? Max reconnection attempts reached');
                
                // Show failure message
                reconnectModal.querySelector('h3').textContent = '? Unable to Reconnect';
                reconnectModal.querySelector('p').textContent = 'Please check your internet connection and refresh the page.';
                const loadingSpinner = reconnectModal.querySelector('.loading');
                if (loadingSpinner) loadingSpinner.style.display = 'none';
            };
        }).catch(error => {
            console.error('? Blazor failed to start:', error);
        });
        
        // Also detect offline event immediately
        window.addEventListener('offline', () => {
            console.log('?? Browser detected offline event');
            
            // Show reconnection modal
            const reconnectModal = document.getElementById('components-reconnect-modal');
            if (reconnectModal) {
                reconnectModal.style.display = 'flex';
            }
            
            // Activate filters after a delay
            setTimeout(() => {
                if (window.gamesFilter && !window.gamesFilter.isActive) {
                    console.log('?? Activating JavaScript filters due to offline event');
                    window.gamesFilter.init();
                }
            }, 2000);
        });
    </script>
</body>
</html>
