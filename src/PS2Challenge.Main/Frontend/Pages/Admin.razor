@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using PS2Challenge.Backend.Data.Repositories
@attribute [Authorize(Roles = "Admin")]
@inject UserRepository UserRepository
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Admin Panel - Dadson's PS2 Challenge</PageTitle>

<div class="admin-container">
    <h1>Admin Panel</h1>

    <AuthorizeView Roles="Admin">
        <Authorized>
            @if (isLoading)
            {
                <div class="loading-container">
                    <div class="loading"></div>
                    <p>Loading admin data...</p>
                </div>
            }
            else
            {
                <div class="admin-navigation">
                    <a href="/games" class="admin-nav-card">
                        <h3>🎮 Games Management</h3>
                        <p>View and manage PS2 games library (use edit icons on Games page)</p>
                    </a>
                    <a href="/admin" class="admin-nav-card active">
                        <h3>👥 User Management</h3>
                        <p>Manage user roles and permissions</p>
                    </a>
                </div>

                <div class="admin-section">
                    <h2>User Management</h2>

                    <div class="users-table-container">
                        <table class="users-table">
                            <thead>
                                <tr>
                                    <th>Profile</th>
                                    <th>Username</th>
                                    <th>Role</th>
                                    <th>Created</th>
                                    <th>Last Login</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in users)
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrEmpty(user.ProfileImageUrl))
                                            {
                                                <img src="@user.ProfileImageUrl" alt="@user.TwitchUsername" class="user-avatar" />
                                            }
                                            else
                                            {
                                                <div class="user-avatar-placeholder">👤</div>
                                            }
                                        </td>
                                        <td>@user.TwitchUsername</td>
                                        <td>
                                            <span class="role-badge @GetRoleBadgeClass(user.Role?.Name)">@user.Role?.Name</span>
                                        </td>
                                        <td>@user.CreatedAt.ToShortDateString()</td>
                                        <td>@user.LastLoginAt.ToShortDateString()</td>
                                        <td>
                                            <select class="role-select"
                                                    value="@user.RoleId"
                                                    @onchange="@(e => UpdateUserRole(user.Id, int.Parse(e.Value?.ToString() ?? "0")))">
                                                @foreach (var role in roles)
                                                {
                                                    <option value="@role.Id">@role.Name</option>
                                                }
                                            </select>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </Authorized>
        <NotAuthorized>
            <div class="auth-message">
                <h2>Access Denied</h2>
                <p>You need to be an administrator to access this page.</p>
                <a href="/" class="btn btn-primary">Go Home</a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private bool isLoading = true;
    private List<PS2Challenge.Backend.Models.ApplicationUser> users = new();
    private List<PS2Challenge.Backend.Models.Role> roles = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;

            roles = await UserRepository.GetAllRolesAsync();
            users = await UserRepository.GetAllUsersAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading admin data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateUserRole(int userId, int roleId)
    {
        try
        {
            var user = await UserRepository.GetByIdAsync(userId);
            if (user != null)
            {
                user.RoleId = roleId;
                await UserRepository.UpdateAsync(user);
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating user role: {ex.Message}");
        }
    }

    private string GetRoleBadgeClass(string? role)
    {
        return role switch
        {
            "Admin" => "role-admin",
            "User" => "role-user",
            _ => "role-default"
        };
    }
}
