@page "/admin"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using PS2Challenge.Backend.Data.Repositories
@using PS2Challenge.Backend.Services
@attribute [Authorize(Roles = "Admin")]
@inject UserRepository UserRepository
@inject GameService GameService
@inject GameCoverService CoverService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Admin Panel - Dadson's PS2 Challenge</PageTitle>

<div class="admin-container">
    <h1>Admin Panel</h1>

    <AuthorizeView Roles="Admin">
        <Authorized>
            @if (isLoading)
            {
                <div class="loading-container">
                    <div class="loading"></div>
                    <p>Loading admin data...</p>
                </div>
            }
            else
            {
                <div class="admin-navigation">
                    <a href="/games" class="admin-nav-card">
                        <h3>🎮 Games Management</h3>
                        <p>View and manage PS2 games library (use edit icons on Games page)</p>
                    </a>
                    <a href="/admin" class="admin-nav-card active">
                        <h3>👥 User Management</h3>
                        <p>Manage user roles and permissions</p>
                    </a>
                </div>

                <div class="admin-section">
                    <h2>Stream Overlays</h2>
                    <p class="help-text">These overlays are designed for use in OBS/streaming software. Click to open in a new tab.</p>
                    
                    <div class="overlays-grid">
                        <a href="/votes-overlay" target="_blank" class="overlay-card">
                            <h3>🗳️ Votes Overlay</h3>
                            <p>Displays current voting results with game titles and vote counts</p>
                            <span class="overlay-size">1242 × 97 px</span>
                        </a>
                        
                        <a href="/vote-covers-overlay" target="_blank" class="overlay-card">
                            <h3>🎨 Vote Covers Overlay</h3>
                            <p>Cycles through game cover images for current votes</p>
                            <span class="overlay-size">1920 × 1080 px</span>
                        </a>
                        
                        <a href="/progress-overlay" target="_blank" class="overlay-card">
                            <h3>📊 Progress Overlay</h3>
                            <p>Shows completed games count and completion percentage</p>
                            <span class="overlay-size">400 × 150 px</span>
                        </a>
                        
                        <a href="/blank-overlay" target="_blank" class="overlay-card">
                            <h3>⬜ Blank Overlay</h3>
                            <p>Background pattern only, no content</p>
                            <span class="overlay-size">1920 × 1080 px</span>
                        </a>
                    </div>
                </div>

                <div class="admin-section">
                    <h2>System Maintenance</h2>
                    
                    <div class="maintenance-card">
                        <h3>🖼️ Update Game Cover Images</h3>
                        <p>Manually trigger an update of all game cover URLs from the ps2-covers repository.</p>
                        <p class="help-text">This process runs automatically every 24 hours, but you can force an immediate update here.</p>
                        
                        @if (isUpdatingCovers)
                        {
                            <div class="update-status">
                                <div class="loading"></div>
                                <p>Updating cover images... This may take a minute.</p>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(coverUpdateMessage))
                        {
                            <div class="update-message @(coverUpdateSuccess ? "success" : "error")">
                                @coverUpdateMessage
                            </div>
                        }
                        
                        <button class="cta-button" 
                                @onclick="UpdateCoverImages" 
                                disabled="@isUpdatingCovers">
                            @if (isUpdatingCovers)
                            {
                                <span>Updating...</span>
                            }
                            else
                            {
                                <span>🔄 Update Cover Images Now</span>
                            }
                        </button>
                    </div>
                </div>

                <div class="admin-section">
                    <h2>User Management</h2>

                    <div class="users-table-container">
                        <table class="users-table">
                            <thead>
                                <tr>
                                    <th>Profile</th>
                                    <th>Username</th>
                                    <th>Role</th>
                                    <th>Created</th>
                                    <th>Last Login</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in users)
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrEmpty(user.ProfileImageUrl))
                                            {
                                                <img src="@user.ProfileImageUrl" alt="@user.TwitchUsername" class="user-avatar" />
                                            }
                                            else
                                            {
                                                <div class="user-avatar-placeholder">👤</div>
                                            }
                                        </td>
                                        <td>@user.TwitchUsername</td>
                                        <td>
                                            <span class="role-badge @GetRoleBadgeClass(user.Role?.Name)">@user.Role?.Name</span>
                                        </td>
                                        <td>@user.CreatedAt.ToShortDateString()</td>
                                        <td>@user.LastLoginAt.ToShortDateString()</td>
                                        <td>
                                            <select class="role-select"
                                                    value="@user.RoleId"
                                                    @onchange="@(e => UpdateUserRole(user.Id, int.Parse(e.Value?.ToString() ?? "0")))">
                                                @foreach (var role in roles)
                                                {
                                                    <option value="@role.Id">@role.Name</option>
                                                }
                                            </select>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </Authorized>
        <NotAuthorized>
            <div class="auth-message">
                <h2>Access Denied</h2>
                <p>You need to be an administrator to access this page.</p>
                <a href="/" class="btn btn-primary">Go Home</a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private bool isLoading = true;
    private bool isUpdatingCovers = false;
    private string coverUpdateMessage = string.Empty;
    private bool coverUpdateSuccess = false;
    
    private List<PS2Challenge.Backend.Models.ApplicationUser> users = new();
    private List<PS2Challenge.Backend.Models.Role> roles = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;

            roles = await UserRepository.GetAllRolesAsync();
            users = await UserRepository.GetAllUsersAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading admin data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateCoverImages()
    {
        isUpdatingCovers = true;
        coverUpdateMessage = string.Empty;
        StateHasChanged();

        try
        {
            Console.WriteLine("Starting manual cover image update...");
            
            // Get all games
            var games = await GameService.GetAllGamesAsync();
            var gamesList = games.ToList();

            Console.WriteLine($"Updating cover URLs for {gamesList.Count} games");

            // Get cover URLs for all games in batch
            var gameIds = gamesList.Select(g => g.Id);
            var coverUrls = await CoverService.GetCoverUrlsAsync(gameIds);

            // Update each game's ImageUrl
            int updatedCount = 0;
            int skippedCount = 0;
            int errorCount = 0;

            foreach (var game in gamesList)
            {
                try
                {
                    if (coverUrls.TryGetValue(game.Id, out var coverUrl))
                    {
                        // Only update if the URL has changed or is null
                        if (game.ImageUrl != coverUrl)
                        {
                            await GameService.UpdateGameCoverUrlAsync(game.Id, coverUrl);
                            updatedCount++;
                        }
                        else
                        {
                            skippedCount++;
                        }
                    }
                    else
                    {
                        // No serial number = no cover
                        if (game.ImageUrl != null)
                        {
                            await GameService.UpdateGameCoverUrlAsync(game.Id, null);
                            updatedCount++;
                        }
                        else
                        {
                            skippedCount++;
                        }
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error updating game {game.Id}: {ex.Message}");
                    errorCount++;
                }
            }

            coverUpdateSuccess = true;
            coverUpdateMessage = $"✅ Update completed successfully! Updated: {updatedCount}, Skipped (unchanged): {skippedCount}, Errors: {errorCount}";
            
            Console.WriteLine($"Cover image update completed. Updated {updatedCount} out of {gamesList.Count} games");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during cover update: {ex.Message}");
            coverUpdateSuccess = false;
            coverUpdateMessage = $"❌ Error updating covers: {ex.Message}";
        }
        finally
        {
            isUpdatingCovers = false;
            StateHasChanged();
        }
    }

    private async Task UpdateUserRole(int userId, int roleId)
    {
        try
        {
            var user = await UserRepository.GetByIdAsync(userId);
            if (user != null)
            {
                user.RoleId = roleId;
                await UserRepository.UpdateAsync(user);
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating user role: {ex.Message}");
        }
    }

    private string GetRoleBadgeClass(string? role)
    {
        return role switch
        {
            "Admin" => "role-admin",
            "User" => "role-user",
            _ => "role-default"
        };
    }
}
