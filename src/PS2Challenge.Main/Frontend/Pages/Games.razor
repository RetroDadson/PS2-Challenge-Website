@page "/games"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Text.Json
@using System.Text.Json.Serialization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.AspNetCore.SignalR.Client
@using PS2Challenge.Main.Frontend.Components
@using PS2Challenge.Main.Frontend.Shared
@using PS2Challenge.Backend.Models
@implements IAsyncDisposable
@inject GameService GameService
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Games - Dadson's PS2 Challenge</PageTitle>

<div class="games-container">
<h1>PS2 Games Library</h1>

<div class="search-section">
    <div class="search-box">
        <input type="text"
               placeholder="Search games by title, developer, or publisher..."
               @bind="searchQuery"
               @bind:event="oninput"
               class="search-input"
               disabled="@isLoading" />
        <span class="search-icon">🔍</span>
    </div>

    <div class="filter-controls">
        <label>
            <input type="checkbox" id="showOwnedOnly" checked="@showOwnedOnly" @onchange="ToggleShowOwnedOnly" disabled="@isLoading" />
            Show Owned Only
        </label>
        <label>
            <input type="checkbox" id="showExcludedGames" checked="@showExcludedGames" @onchange="ToggleShowExcluded" disabled="@isLoading" />
            Show Excluded Games
        </label>
    </div>

    @if (isLoading)
    {
        <div class="results-count">
            <p>Loading games data...</p>
        </div>
    }
    else
    {
        <div class="results-count">
            <p>Showing @FilteredGames.Count() of @_totalGames games | Owned: @_ownedCount | Excluded: @_excludedCount | Completed: @_completedCount | In Progress: @_inProgressCount | Not Started: @_notStartedCount</p>
        </div>
    }

    @if (isAdmin)
    {
        <div class="admin-actions">
            <button class="cta-button" @onclick="OpenAddModal" disabled="@isLoading">+ Add New Game</button>
        </div>
    }
</div>

<div class="games-table-container">
    <table class="games-table">
        <thead>
            <tr>
                @if (isAdmin)
                {
                    <th style="width: 80px;">Actions</th>
                }
                <th style="width: 100px;">Cover</th>
                <th @onclick="() => SortBy(nameof(GameDto.Title))">Title @GetSortIcon(nameof(GameDto.Title))</th>
                <th @onclick="() => SortBy(nameof(GameDto.Developer))">Developer @GetSortIcon(nameof(GameDto.Developer))</th>
                <th @onclick="() => SortBy(nameof(GameDto.Publisher))">Publisher @GetSortIcon(nameof(GameDto.Publisher))</th>
                <th @onclick="() => SortBy(nameof(GameDto.FirstReleased))">Release Date @GetSortIcon(nameof(GameDto.FirstReleased))</th>
                <th @onclick="() => SortBy(nameof(GameDto.RegionFirstReleasedIn))">Region First Released In @GetSortIcon(nameof(GameDto.RegionFirstReleasedIn))</th>
                <th @onclick='() => SortBy("IsExcluded")'>Excluded @GetSortIcon("IsExcluded")</th>
                <th @onclick='() => SortBy("IsOwned")'>Owned @GetSortIcon("IsOwned")</th>
                <th @onclick='() => SortBy("CompletionStatus")'>Status @GetSortIcon("CompletionStatus")</th>
            </tr>
        </thead>
        <tbody>
            @if (isLoading)
            {
                <tr>
                    <td colspan="@(isAdmin ? 10 : 9)" style="text-align: center; padding: 3rem;">
                        <div class="loading-container">
                            <div class="loading"></div>
                            <p>Loading games...</p>
                        </div>
                    </td>
                </tr>
            }
            else if (allGames == null || !allGames.Any())
            {
                <tr>
                    <td colspan="@(isAdmin ? 10 : 9)" style="text-align: center; padding: 2rem;">
                        <p>No games found.</p>
                    </td>
                </tr>
            }
            else
            {
                    <Virtualize Items="@FilteredGames.ToList()" Context="game" OverscanCount="20">
                        <tr class="@GetRowClass(game)">
                            @if (isAdmin)
                            {
                                <td>
                                    <button class="btn-icon" @onclick="() => OpenEditModal(game)" title="Edit">
                                        ✏️
                                    </button>
                                </td>
                            }
                            <td class="cover-cell">
                                @if (!string.IsNullOrEmpty(game.ImageUrl))
                                {
                                    <div class="cover-wrapper">
                                        <img src="@game.ImageUrl" 
                                             alt="@game.Title cover" 
                                             class="game-cover"
                                             loading="lazy"
                                             width="80"
                                             height="112"
                                             onerror="this.style.display='none'" />
                                    </div>
                                }
                                else
                                {
                                    <div class="no-cover">No Cover</div>
                                }
                            </td>
                            <td>
                                @if (alternateTitles.ContainsKey(game.Id) && alternateTitles[game.Id].Any())
                                {
                                    <HoverCard Content="@GetAlternateTitles(game.Id)">
                                        <span style="border-bottom: 1px dotted var(--primary-color);">@game.Title</span>
                                    </HoverCard>
                                }
                                else
                                {
                                    @game.Title
                                }
                            </td>
                            <td>@game.Developer</td>
                            <td>@game.Publisher</td>
                            <td>@(game.FirstReleased?.ToString("dd/MM/yyyy") ?? "Unknown")</td>
                            <td>@game.RegionFirstReleasedIn</td>
                            <td style="white-space: nowrap;">
                                @if (game.IsExcluded)
                                {
                                    <HoverCard Content="@GetExclusionReason(game.Id)">
                                        <span class="badge excluded-badge">Excluded</span>
                                    </HoverCard>
                                }
                                else
                                {
                                    <span class="badge included-badge">Included</span>
                                }
                            </td>
                            <td style="white-space: nowrap;">
                                @if (game.IsOwned)
                                {
                                    <HoverCard Content="@GetTypeOwned(game.Id)">
                                        <span class="badge owned-badge">✓ Owned</span>
                                    </HoverCard>
                                }
                                else
                                {
                                    <span class="badge not-owned-badge">To Purchase</span>
                                }
                            </td>
                            <td style="white-space: nowrap;">
                                @{
                                    var status = GetCompletionStatus(game.Id);
                                }
                                @if (status == "Completed")
                                {
                                    <span class="badge status-completed">✓ Completed</span>
                                }
                                else if (status == "In Progress")
                                {
                                    <span class="badge status-inprogress">⏳ In Progress</span>
                                }
                                else
                                {
                                    <span class="badge status-notstarted">Not Started</span>
                                }
                            </td>
                        </tr>
                    </Virtualize>
                }
                </tbody>
            </table>
        </div>
</div>

<GameEditModal 
    IsVisible="@showModal"
    IsEditMode="@isEditMode"
    Game="@selectedGame"
    OnClose="@CloseModal"
    OnSave="@HandleSave"
    OnDelete="@HandleDelete" />

@code {
private List<GameDto> allGames = new();
private Dictionary<int, string> ownedTypes = new();
private Dictionary<int, string> exclusionReasons = new();
private Dictionary<int, string> completionStatus = new();
private Dictionary<int, List<AlternateTitle>> alternateTitles = new();

private string searchQuery = string.Empty;
private bool showOwnedOnly = false;
private bool showExcludedGames = false;
private string sortColumn = nameof(GameDto.Title);
private bool sortAscending = true;
private bool isLoading = true;
private bool isAdmin = false;

private bool showModal = false;
private bool isEditMode = false;
private GameDto? selectedGame = null;

// Cache filtered results to avoid recomputing on every access
private List<GameDto>? _cachedFilteredGames = null;
private string? _lastSearchQuery = null;
private bool _lastShowOwnedOnly = false;
private bool _lastShowExcludedGames = false;
private string? _lastSortColumn = null;
private bool _lastSortAscending = true;

// Cache statistics to avoid multiple enumerations
private int _totalGames = 0;
private int _ownedCount = 0;
private int _excludedCount = 0;
private int _completedCount = 0;
private int _inProgressCount = 0;
private int _notStartedCount = 0;

// SignalR connection
private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        // Load admin status first as it doesn't depend on other data
        await CheckAdminStatus();
        
        // Load all games page data in a single optimized call
        await LoadAllData();

        // Set up SignalR connection for real-time updates
        await InitializeSignalRConnection();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load user preferences from localStorage after first render
            // This must be done after render as JSRuntime is not available during SSR
            await LoadPreferences();
            // Only trigger re-render if preferences were actually loaded and affect display
            if (showOwnedOnly || showExcludedGames)
            {
                StateHasChanged();
            }
        }
    }

    private async Task CheckAdminStatus()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                isAdmin = string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);
            }
        }
        catch
        {
            isAdmin = false;
        }
    }

    private async Task LoadPreferences()
    {
        try
        {
            var ownedPref = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "showOwnedOnly");
            var excludedPref = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "showExcludedGames");

            if (!string.IsNullOrEmpty(ownedPref) && bool.TryParse(ownedPref, out var ownedVal))
            {
                showOwnedOnly = ownedVal;
            }
            if (!string.IsNullOrEmpty(excludedPref) && bool.TryParse(excludedPref, out var excludedVal))
            {
                showExcludedGames = excludedVal;
            }
        }
        catch
        {
            // ignore errors reading preferences
        }
    }

    private async Task SavePreferences()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "showOwnedOnly", showOwnedOnly.ToString());
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "showExcludedGames", showExcludedGames.ToString());
        }
        catch
        {
            // ignore
        }
    }

    private void ToggleShowOwnedOnly(ChangeEventArgs e)
    {
        showOwnedOnly = e.Value is bool b && b;
        // Save preferences asynchronously without blocking the UI
        _ = SavePreferences();
        // No need to call StateHasChanged() - Blazor does this automatically after event handlers
    }

    private void ToggleShowExcluded(ChangeEventArgs e)
    {
        showExcludedGames = e.Value is bool b && b;
        // Save preferences asynchronously without blocking the UI
        _ = SavePreferences();
        // No need to call StateHasChanged() - Blazor does this automatically after event handlers
    }

    private async Task LoadGames()
    {
        try
        {
            var result = await GameService.GetAllGamesAsync();
            allGames = result?.ToList() ?? new List<GameDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading games: {ex.Message}");
            allGames = new List<GameDto>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadAllData()
    {
        try
        {
            var pageData = await GameService.GetGamesPageDataAsync();
            
            if (pageData != null)
            {
                allGames = pageData.Games ?? new List<GameDto>();
                ownedTypes = pageData.OwnedTypes ?? new Dictionary<int, string>();
                exclusionReasons = pageData.ExclusionReasons ?? new Dictionary<int, string>();
                completionStatus = pageData.CompletionStatus ?? new Dictionary<int, string>();
                alternateTitles = pageData.AlternateTitles ?? new Dictionary<int, List<AlternateTitle>>();
                
                // Pre-compute statistics once
                ComputeStatistics();
                
                // Invalidate cache when data changes
                _cachedFilteredGames = null;
            }
            else
            {
                allGames = new List<GameDto>();
                ownedTypes = new();
                exclusionReasons = new();
                completionStatus = new();
                alternateTitles = new();
                ComputeStatistics();
                _cachedFilteredGames = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ERROR loading games: {ex.Message}");
            allGames = new List<GameDto>();
            ownedTypes = new();
            exclusionReasons = new();
            completionStatus = new();
            alternateTitles = new();
            ComputeStatistics();
            _cachedFilteredGames = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ComputeStatistics()
    {
        _totalGames = allGames.Count;
        _ownedCount = 0;
        _excludedCount = 0;
        _completedCount = 0;
        _inProgressCount = 0;
        _notStartedCount = 0;

        foreach (var game in allGames)
        {
            if (game.IsOwned) _ownedCount++;
            if (game.IsExcluded) _excludedCount++;

            if (!game.IsExcluded)
            {
                if (completionStatus.TryGetValue(game.Id, out var status))
                {
                    if (status == "Completed")
                        _completedCount++;
                    else if (status == "In Progress")
                        _inProgressCount++;
                    else
                        _notStartedCount++;
                }
                else
                {
                    _notStartedCount++;
                }
            }
        }
    }

    private async Task LoadOwnedTypes()
    {
        try
        {
            ownedTypes = await GameService.GetOwnedTypesAsync();
        }
        catch
        {
            ownedTypes = new();
        }
    }

    private async Task LoadExclusionReasons()
    {
        try
        {
            exclusionReasons = await GameService.GetExclusionReasonsAsync();
        }
        catch
        {
            exclusionReasons = new();
        }
    }

    private async Task LoadCompletionStatus()
    {
        try
        {
            completionStatus = await GameService.GetCompletionStatusAsync();
        }
        catch
        {
            completionStatus = new();
        }
    }

    private async Task LoadAlternateTitles()
    {
        try
        {
            alternateTitles = await GameService.GetAlternateTitlesAsync();
        }
        catch
        {
            alternateTitles = new();
        }
    }

    private string GetTypeOwned(int gameId)
    {
        if (ownedTypes.TryGetValue(gameId, out var t))
        {
            return string.IsNullOrWhiteSpace(t) ? "Owned" : t;
        }
        return "Owned";
    }

    private string GetExclusionReason(int gameId)
    {
        if (exclusionReasons.TryGetValue(gameId, out var reason))
        {
            return reason;
        }
        return "No reason provided";
    }

    private string GetCompletionStatus(int gameId)
    {
        if (completionStatus.TryGetValue(gameId, out var status))
        {
            return status;
        }
        return "Not Started";
    }

    private string GetAlternateTitles(int gameId)
    {
        if (alternateTitles.TryGetValue(gameId, out var titles) && titles.Any())
        {
            return string.Join("<br />", titles.Select(t => t.Title));
        }
        return "No alternate titles";
    }

    private void OpenAddModal()
    {
        selectedGame = new GameDto();
        isEditMode = false;
        showModal = true;
        StateHasChanged();
    }

    private void OpenEditModal(GameDto game)
    {
        selectedGame = game;
        isEditMode = true;
        showModal = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        showModal = false;
        selectedGame = null;
        StateHasChanged();
    }

    private async Task HandleSave()
    {
        // Reload all data after save using the optimized single call
        await LoadAllData();
        CloseModal();
    }

    private async Task HandleDelete(int gameId)
    {
        // Reload all data after delete using the optimized single call
        await LoadAllData();
        CloseModal();
    }

    private IEnumerable<GameDto> FilteredGames
    {
        get
        {
            // Check if cache is still valid
            if (_cachedFilteredGames != null &&
                _lastSearchQuery == searchQuery &&
                _lastShowOwnedOnly == showOwnedOnly &&
                _lastShowExcludedGames == showExcludedGames &&
                _lastSortColumn == sortColumn &&
                _lastSortAscending == sortAscending)
            {
                return _cachedFilteredGames;
            }

            // Cache is invalid, recalculate using optimized approach
            var count = allGames.Count;
            var results = new List<GameDto>(count);

            // Fast path: no search query
            if (string.IsNullOrWhiteSpace(searchQuery))
            {
                // Apply filters in a single pass
                for (int i = 0; i < count; i++)
                {
                    var game = allGames[i];
                    
                    if (showOwnedOnly && !game.IsOwned) continue;
                    if (!showExcludedGames && game.IsExcluded) continue;
                    
                    results.Add(game);
                }
            }
            else
            {
                // Search path: filter with search query
                var q = searchQuery.ToLowerInvariant();
                
                for (int i = 0; i < count; i++)
                {
                    var game = allGames[i];
                    
                    // Apply ownership and exclusion filters first (cheaper)
                    if (showOwnedOnly && !game.IsOwned) continue;
                    if (!showExcludedGames && game.IsExcluded) continue;
                    
                    // Then check search query
                    bool matchesSearch = 
                        (game.Title?.ToLowerInvariant().Contains(q) ?? false) ||
                        (game.Developer?.ToLowerInvariant().Contains(q) ?? false) ||
                        (game.Publisher?.ToLowerInvariant().Contains(q) ?? false);
                    
                    if (!matchesSearch && alternateTitles.TryGetValue(game.Id, out var titles))
                    {
                        foreach (var title in titles)
                        {
                            if (title.Title.ToLowerInvariant().Contains(q))
                            {
                                matchesSearch = true;
                                break;
                            }
                        }
                    }
                    
                    if (matchesSearch)
                    {
                        results.Add(game);
                    }
                }
            }

            // Sort the results
            results = sortColumn switch
            {
                nameof(GameDto.Developer) => sortAscending 
                    ? results.OrderBy(g => g.Developer).ToList()
                    : results.OrderByDescending(g => g.Developer).ToList(),
                nameof(GameDto.Publisher) => sortAscending 
                    ? results.OrderBy(g => g.Publisher).ToList()
                    : results.OrderByDescending(g => g.Publisher).ToList(),
                nameof(GameDto.FirstReleased) => sortAscending 
                    ? results.OrderBy(g => g.FirstReleased ?? DateOnly.MinValue).ToList()
                    : results.OrderByDescending(g => g.FirstReleased ?? DateOnly.MinValue).ToList(),
                nameof(GameDto.RegionFirstReleasedIn) => sortAscending 
                    ? results.OrderBy(g => g.RegionFirstReleasedIn).ToList()
                    : results.OrderByDescending(g => g.RegionFirstReleasedIn).ToList(),
                "IsExcluded" => sortAscending 
                    ? results.OrderBy(g => g.IsExcluded).ToList()
                    : results.OrderByDescending(g => g.IsExcluded).ToList(),
                "IsOwned" => sortAscending 
                    ? results.OrderBy(g => g.IsOwned).ToList()
                    : results.OrderByDescending(g => g.IsOwned).ToList(),
                "CompletionStatus" => sortAscending 
                    ? results.OrderBy(g => GetCompletionStatus(g.Id)).ToList()
                    : results.OrderByDescending(g => GetCompletionStatus(g.Id)).ToList(),
                _ => sortAscending 
                    ? results.OrderBy(g => g.Title).ToList()
                    : results.OrderByDescending(g => g.Title).ToList()
            };

            // Cache the result
            _cachedFilteredGames = results;
            _lastSearchQuery = searchQuery;
            _lastShowOwnedOnly = showOwnedOnly;
            _lastShowExcludedGames = showExcludedGames;
            _lastSortColumn = sortColumn;
            _lastSortAscending = sortAscending;

            return _cachedFilteredGames;
        }
    }

    private string GetSortIcon(string column) => sortColumn == column ? (sortAscending ? "▲" : "▼") : string.Empty;

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private string GetRowClass(GameDto game)
    {
        if (game.IsExcluded)
            return "excluded-row";
        if (game.IsOwned)
            return "owned-row";
        return string.Empty;
    }

    private async Task InitializeSignalRConnection()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/gamesHub"))
                .WithAutomaticReconnect()
                .Build();

            // Subscribe to GamesUpdated event
            hubConnection.On("GamesUpdated", async () =>
            {
                Console.WriteLine("SignalR: Received GamesUpdated notification - refreshing game data");
                await LoadAllData();
                await InvokeAsync(StateHasChanged);
            });

            await hubConnection.StartAsync();
            Console.WriteLine("SignalR: Connected to GamesHub");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignalR: Error connecting to hub: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            try
            {
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error disposing SignalR connection: {ex.Message}");
            }
        }
    }
}