@page "/login"
@inject NavigationManager Navigation

<PageTitle>Login - Dadson's PS2 Challenge</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <h2>Login with Twitch</h2>
        <p>Sign in using your Twitch account to access additional features.</p>

        <a href="@GetLoginUrl()" class="btn btn-twitch">
            <span class="twitch-icon">📺</span>
            Login with Twitch
        </a>

        <p class="mt-3 text-muted">
            Your account will be created automatically on first login.
        </p>
    </div>
</div>

@code {
    private string GetLoginUrl()
    {
        // Get the returnUrl from query string if present, otherwise use referrer or home
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var returnUrl = query["returnUrl"] ?? "/";

        // If no returnUrl in query, use the current full URL (which is /login)
        // In this case, default to home page
        if (string.IsNullOrEmpty(returnUrl))
        {
            returnUrl = Navigation.BaseUri; // Use base URI (home page)
        }

        var encodedReturn = Uri.EscapeDataString(returnUrl);
        return $"/api/auth/login?returnUrl={encodedReturn}";
    }
}
