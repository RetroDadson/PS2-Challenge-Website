@page "/progress"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore
@using PS2Challenge.Backend.Data
@using PS2Challenge.Main.Frontend.Components
@using PS2Challenge.Main.Frontend.Shared
@implements IAsyncDisposable
@inject GameService GameService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager NavigationManager
@using System.Globalization
@using PS2Challenge.Backend.Models

<PageTitle>Game Progress - Dadson's PS2 Tracker</PageTitle>

<div class="completed-games-container">
<h1>Game Progress</h1>

@if (isAdmin)
{
    <div style="margin-bottom:1rem;">
        <button class="cta-button" @onclick="OpenAddModal" disabled="@isLoading">Add New Game</button>
    </div>
}

<div class="search-section">
    <div class="search-box">
        <input type="text"
               placeholder="Search by title, criteria, or review..."
               @bind="searchQuery"
               @bind:event="oninput"
               class="search-input"
               disabled="@isLoading" />
        <span class="search-icon">🔍</span>
    </div>

    <div class="filter-controls">
        <label>
            <input type="checkbox" id="showCompletedOnly" checked="@showCompletedOnly" @onchange="ToggleShowCompletedOnly" disabled="@isLoading" />
            Show Completed Only
        </label>
        <label>
            <input type="checkbox" id="showInProgressOnly" checked="@showInProgressOnly" @onchange="ToggleShowInProgressOnly" disabled="@isLoading" />
            Show In Progress Only
        </label>
    </div>

    @if (isLoading)
    {
        <div class="results-count">
            <p>Loading game progress data...</p>
        </div>
    }
    else
    {
        <div class="results-count">
            <p>Showing @FilteredGames.Count() of @_totalGames games | Completed: @_completedCount | In Progress: @_inProgressCount</p>
        </div>
    }
</div>

<div class="games-table-container">
    <table class="games-table">
        <thead>
            <tr>
                <th @onclick="() => SortBy(nameof(GameProgressDto.ProgressId))">
                    Game Number @GetSortIcon(nameof(GameProgressDto.ProgressId))
                </th>
                <th @onclick='() => SortBy("Status")'>
                    Status @GetSortIcon("Status")
                </th>
                <th style="width: 100px;">Cover</th>
                <th @onclick="() => SortBy(nameof(GameProgressDto.GameTitle))">
                    Title @GetSortIcon(nameof(GameProgressDto.GameTitle))
                </th>
                <th @onclick="() => SortBy(nameof(GameProgressDto.DateStarted))">
                    Started @GetSortIcon(nameof(GameProgressDto.DateStarted))
                </th>
                <th @onclick="() => SortBy(nameof(GameProgressDto.DateFinished))">
                    Finished @GetSortIcon(nameof(GameProgressDto.DateFinished))
                </th>
                <th @onclick="() => SortBy(nameof(GameProgressDto.CompletionTime))">
                    Time @GetSortIcon(nameof(GameProgressDto.CompletionTime))
                </th>
                <th @onclick="() => SortBy(nameof(GameProgressDto.Platform))">
                    Platform @GetSortIcon(nameof(GameProgressDto.Platform))
                </th>
                <th>Criteria</th>
                <th>Review</th>
                @if (isAdmin)
                {
                    <th style="width:100px">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (isLoading)
            {
                <tr>
                    <td colspan="@(isAdmin ? 11 : 10)" style="text-align: center; padding: 3rem;">
                        <div class="loading-container">
                            <div class="loading"></div>
                            <p>Loading game progress...</p>
                        </div>
                    </td>
                </tr>
            }
            else if (gamesWithProgress == null || !gamesWithProgress.Any())
            {
                <tr>
                    <td colspan="@(isAdmin ? 11 : 10)" style="text-align: center; padding: 2rem;">
                        <p>No games in progress found.</p>
                    </td>
                </tr>
            }
            else
            {
                    <Virtualize Items="@FilteredGames.ToList()" Context="game" OverscanCount="20">
                        <tr class="@(game.DateFinished.HasValue ? "completed" : "in-progress")">
                            <td>@game.ProgressId</td>
                            <td>
                                <span class="status-badge @(game.DateFinished.HasValue ? "status-completed" : "status-inprogress")">
                                    @(game.DateFinished.HasValue ? "Completed" : "In Progress")
                                </span>
                            </td>
                            <td class="cover-cell">
                                @if (!string.IsNullOrEmpty(game.ImageUrl))
                                {
                                    <div class="cover-wrapper">
                                        <img src="@game.ImageUrl" 
                                             alt="@game.GameTitle cover" 
                                             class="game-cover"
                                             loading="lazy"
                                             width="80"
                                             height="112"
                                             onerror="this.style.display='none'" />
                                    </div>
                                }
                                else
                                {
                                    <div class="no-cover">No Cover</div>
                                }
                            </td>
                            <td class="game-title">
                                @if (alternateTitles.ContainsKey(game.GameId) && alternateTitles[game.GameId].Any())
                                {
                                    <HoverCard Content="@GetAlternateTitles(game.GameId)">
                                        <span style="border-bottom: 1px dotted var(--primary-color);">@game.GameTitle</span>
                                    </HoverCard>
                                }
                                else
                                {
                                    @game.GameTitle
                                }
                            </td>
                            <td>@game.DateStarted.ToString("dd/MM/yyyy")</td>
                            <td>@(game.DateFinished?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>@FormatCompletionTime(game.CompletionTime)</td>
                            <td><span class="platform-badge platform-@game.Platform.ToLower()">@game.Platform</span></td>
                            <td class="criteria">@(game.BeatenCriteria ?? "-")</td>
                            <td class="review">@(game.Review ?? "-")</td>
                            @if (isAdmin)
                            {
                                <td>
                                    <button class="btn btn-link" @onclick="() => OpenEditModal(game)">Edit</button>
                                </td>
                            }
                        </tr>
                    </Virtualize>
                }
                </tbody>
            </table>
        </div>
</div>

<GameProgressEdit IsVisible="@showModal"
                  IsEditMode="@isEditMode"
                  ProgressId="@editingProgressId"
                  AllGameTitles="@allGameTitles"
                  GameTitle="@editGameTitle"
                  DateStarted="@editDateStarted"
                  DateFinished="@editDateFinished"
                  Platform="@editPlatform"
                  BeatenCriteria="@editBeatenCriteria"
                  Review="@editReview"
                  CompletionHours="@editCompletionHours"
                  CompletionMinutes="@editCompletionMinutes"
                  CompletionSeconds="@editCompletionSeconds"
                  OnClose="@CloseModal"
                  OnSave="@HandleSave" />

@code {
private IEnumerable<GameProgressDto>? gamesWithProgress;
private Dictionary<int, List<AlternateTitle>> alternateTitles = new();
private bool isLoading = true;
private bool isAdmin = false;
private string searchQuery = "";
private bool showCompletedOnly = false;
private bool showInProgressOnly = false;
private string sortColumn = "ProgressId";
private bool sortAscending = false;

// Modal state
private bool showModal = false;
private bool isEditMode = false;
private int? editingProgressId = null;

// Edit/Add form state
private string editGameTitle = string.Empty;
private DateTime? editDateStarted;
private DateTime? editDateFinished;
private string editPlatform = "Physical";
private string? editBeatenCriteria;
private string? editReview;
private int editCompletionHours = 0;
private int editCompletionMinutes = 0;
private int editCompletionSeconds = 0;

// suggestions
private List<string> allGameTitles = new();

// Cache filtered results to avoid recomputing on every access
private List<GameProgressDto>? _cachedFilteredGames = null;
private string? _lastSearchQuery = null;
private bool _lastShowCompletedOnly = false;
private bool _lastShowInProgressOnly = false;
private string? _lastSortColumn = null;
private bool _lastSortAscending = true;

// Cache statistics to avoid multiple enumerations
private int _totalGames = 0;
private int _completedCount = 0;
private int _inProgressCount = 0;

// SignalR connection
private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await CheckAdminStatus();
        await LoadProgress();
        await LoadAlternateTitles();

        if (isAdmin)
        {
            await LoadAllGameTitles();
        }

        // Set up SignalR connection for real-time updates
        await InitializeSignalRConnection();
    }

    private async Task CheckAdminStatus()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                isAdmin = string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);
            }
        }
        catch
        {
            isAdmin = false;
        }
    }

    private async Task LoadProgress()
    {
        try
        {
            isLoading = true;
            gamesWithProgress = await GameService.GetAllProgressAsync();
            
            // Pre-compute statistics once
            ComputeStatistics();
            
            // Invalidate cache when data changes
            _cachedFilteredGames = null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading game progress: {ex.Message}");
            gamesWithProgress = new List<GameProgressDto>();
            ComputeStatistics();
            _cachedFilteredGames = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ComputeStatistics()
    {
        if (gamesWithProgress == null)
        {
            _totalGames = 0;
            _completedCount = 0;
            _inProgressCount = 0;
            return;
        }

        var gamesList = gamesWithProgress.ToList();
        _totalGames = gamesList.Count;
        _completedCount = 0;
        _inProgressCount = 0;

        foreach (var game in gamesList)
        {
            if (game.DateFinished.HasValue)
                _completedCount++;
            else
                _inProgressCount++;
        }
    }

    private async Task LoadAllGameTitles()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<Ps2ChallengeDbContext>();

            allGameTitles = await db.Games
                .AsNoTracking()
                .Select(g => g.Title)
                .Where(t => !string.IsNullOrWhiteSpace(t))
                .Distinct()
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading game titles for suggestions: {ex.Message}");
            allGameTitles = new List<string>();
        }
    }

    private async Task LoadAlternateTitles()
    {
        try
        {
            alternateTitles = await GameService.GetAlternateTitlesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading alternate titles: {ex.Message}");
            alternateTitles = new();
        }
    }

    private string GetAlternateTitles(int gameId)
    {
        if (alternateTitles.TryGetValue(gameId, out var titles) && titles.Any())
        {
            return string.Join("<br />", titles.Select(t => t.Title));
        }
        return "No alternate titles";
    }

    private void OpenAddModal()
    {
        if (!isAdmin) return;

        isEditMode = false;
        editingProgressId = null;
        ClearFormFields();
        showModal = true;
    }

    private void OpenEditModal(GameProgressDto game)
    {
        if (!isAdmin) return;

        isEditMode = true;
        editingProgressId = game.ProgressId;
        
        editGameTitle = game.GameTitle;
        editDateStarted = game.DateStarted.ToDateTime(TimeOnly.MinValue);
        editDateFinished = game.DateFinished?.ToDateTime(TimeOnly.MinValue);
        editPlatform = game.Platform ?? "Physical";
        editBeatenCriteria = game.BeatenCriteria;
        editReview = game.Review;

        if (game.CompletionTime.HasValue)
        {
            editCompletionHours = (int)game.CompletionTime.Value.TotalHours;
            editCompletionMinutes = game.CompletionTime.Value.Minutes;
            editCompletionSeconds = game.CompletionTime.Value.Seconds;
        }
        else
        {
            editCompletionHours = 0;
            editCompletionMinutes = 0;
            editCompletionSeconds = 0;
        }

        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        ClearFormFields();
    }

    private void ClearFormFields()
    {
        editGameTitle = string.Empty;
        editDateStarted = null;
        editDateFinished = null;
        editPlatform = "Physical";
        editBeatenCriteria = null;
        editReview = null;
        editCompletionHours = 0;
        editCompletionMinutes = 0;
        editCompletionSeconds = 0;
        editingProgressId = null;
    }

    private async Task HandleSave()
    {
        await LoadProgress();
        CloseModal();
    }

    private IEnumerable<GameProgressDto> FilteredGames
    {
        get
        {
            // Check if cache is still valid
            if (_cachedFilteredGames != null &&
                _lastSearchQuery == searchQuery &&
                _lastShowCompletedOnly == showCompletedOnly &&
                _lastShowInProgressOnly == showInProgressOnly &&
                _lastSortColumn == sortColumn &&
                _lastSortAscending == sortAscending)
            {
                return _cachedFilteredGames;
            }

            // Cache is invalid, recalculate using optimized approach
            IEnumerable<GameProgressDto> filtered = gamesWithProgress ?? Enumerable.Empty<GameProgressDto>();

            // Apply filters in a single pass
            var results = new List<GameProgressDto>();
            
            foreach (var game in filtered)
            {
                // Apply status filters
                if (showCompletedOnly && !game.DateFinished.HasValue) continue;
                if (showInProgressOnly && game.DateFinished.HasValue) continue;

                // Apply search filter
                if (!string.IsNullOrWhiteSpace(searchQuery))
                {
                    var matchesSearch = 
                        game.GameTitle.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                        (game.BeatenCriteria != null && game.BeatenCriteria.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) ||
                        (game.Review != null && game.Review.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
                    
                    if (!matchesSearch) continue;
                }

                results.Add(game);
            }

            // Sort the results
            results = sortColumn switch
            {
                nameof(GameProgressDto.ProgressId) => sortAscending 
                    ? results.OrderBy(g => g.ProgressId).ToList() 
                    : results.OrderByDescending(g => g.ProgressId).ToList(),
                "Status" => sortAscending 
                    ? results.OrderBy(g => g.DateFinished.HasValue).ThenBy(g => g.GameTitle).ToList() 
                    : results.OrderByDescending(g => g.DateFinished.HasValue).ThenByDescending(g => g.GameTitle).ToList(),
                nameof(GameProgressDto.GameTitle) => sortAscending 
                    ? results.OrderBy(g => g.GameTitle).ToList() 
                    : results.OrderByDescending(g => g.GameTitle).ToList(),
                nameof(GameProgressDto.DateStarted) => sortAscending 
                    ? results.OrderBy(g => g.DateStarted).ToList() 
                    : results.OrderByDescending(g => g.DateStarted).ToList(),
                nameof(GameProgressDto.DateFinished) => sortAscending 
                    ? results.OrderBy(g => g.DateFinished ?? DateOnly.MaxValue).ToList() 
                    : results.OrderByDescending(g => g.DateFinished ?? DateOnly.MinValue).ToList(),
                nameof(GameProgressDto.CompletionTime) => sortAscending 
                    ? results.OrderBy(g => g.CompletionTime ?? TimeSpan.MaxValue).ToList() 
                    : results.OrderByDescending(g => g.CompletionTime ?? TimeSpan.MinValue).ToList(),
                nameof(GameProgressDto.Platform) => sortAscending 
                    ? results.OrderBy(g => g.Platform).ToList() 
                    : results.OrderByDescending(g => g.Platform).ToList(),
                _ => results.OrderByDescending(g => g.ProgressId).ToList()
            };

            // Cache the result
            _cachedFilteredGames = results;
            _lastSearchQuery = searchQuery;
            _lastShowCompletedOnly = showCompletedOnly;
            _lastShowInProgressOnly = showInProgressOnly;
            _lastSortColumn = sortColumn;
            _lastSortAscending = sortAscending;

            return _cachedFilteredGames;
        }
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private string GetSortIcon(string column)
    {
        if (sortColumn != column)
        {
            return "";
        }

        return sortAscending ? "▲" : "▼";
    }

    private string FormatCompletionTime(TimeSpan? timeSpan)
    {
        if (timeSpan == null) return "-";

        var hours = (int)timeSpan.Value.TotalHours;
        var minutes = timeSpan.Value.Minutes;
        var seconds = timeSpan.Value.Seconds;

        return $"{hours:D2}:{minutes:D2}:{seconds:D2}";
    }

    private void ToggleShowCompletedOnly(ChangeEventArgs e)
    {
        showCompletedOnly = e.Value is bool b && b;
        // No need to call StateHasChanged() - Blazor does this automatically after event handlers
    }

    private void ToggleShowInProgressOnly(ChangeEventArgs e)
    {
        showInProgressOnly = e.Value is bool b && b;
        // No need to call StateHasChanged() - Blazor does this automatically after event handlers
    }

    private async Task InitializeSignalRConnection()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/gamesHub"))
                .WithAutomaticReconnect()
                .Build();

            // Subscribe to GamesUpdated event
            hubConnection.On("GamesUpdated", async () =>
            {
                Console.WriteLine("SignalR: Received GamesUpdated notification - refreshing progress data");
                await LoadProgress();
                await InvokeAsync(StateHasChanged);
            });

            await hubConnection.StartAsync();
            Console.WriteLine("SignalR: Connected to GamesHub");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignalR: Error connecting to hub: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            try
            {
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error disposing SignalR connection: {ex.Message}");
            }
        }
    }
}