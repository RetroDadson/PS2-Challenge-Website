@page "/progress-overlay"
@rendermode InteractiveServer
@layout EmptyLayout
@using PS2Challenge.Backend.Models
@using Microsoft.EntityFrameworkCore
@using PS2Challenge.Backend.Data
@using Microsoft.AspNetCore.SignalR.Client
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

@*
    Progress Overlay - Stream/OBS Overlay Component
    
    Displays the current challenge progress showing:
    - Number of games completed
    - Total games in challenge
    - Completion percentage
    
    Designed to be displayed as a browser source in OBS/streaming software.
    Uses SignalR to auto-update when game progress changes.
    Access via: /progress-overlay
*@

<div class="overlay-container">
    @if (isLoading)
    {
        <div class="loading">Loading...</div>
    }
    else if (hasError)
    {
        <div class="loading">Error loading progress</div>
    }
    else
    {
        <div class="progress-box">
            <div class="progress-label">Games Completed</div>
            <div class="progress-count">@gamesCompletedCount / @gamesInChallengeCount</div>
            <div class="progress-percentage">@percentageComplete.ToString("F2")%</div>
        </div>
    }
</div>

@code {
    private int gamesCompletedCount = 0;
    private int gamesInChallengeCount = 0;
    private double percentageComplete = 0;
    private bool isLoading = true;
    private bool hasError = false;
    private bool isDisposed = false;
    private HubConnection? hubConnection;
    private string? lastDataHash;
    private readonly object _stateLock = new object();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadProgressData();

            hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/gamesHub"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On("GamesUpdated", async () =>
            {
                try
                {
                    if (isDisposed) return;
                    
                    await LoadProgressData();
                    
                    if (!isDisposed)
                    {
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error in GamesUpdated handler: {ex.Message}");
                }
            });

            try
            {
                await hubConnection.StartAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error connecting to SignalR hub: {ex.Message}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in OnInitializedAsync: {ex.Message}");
            hasError = true;
            isLoading = false;
        }
    }

    private async Task LoadProgressData()
    {
        try
        {
            if (isDisposed) return;
            
            isLoading = true;
            hasError = false;
            
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<Ps2ChallengeDbContext>();

            var excludedGameIds = await db.ExcludedGames
                .AsNoTracking()
                .Select(eg => eg.GameId)
                .ToListAsync();

            var totalGames = await db.Games
                .AsNoTracking()
                .Where(g => !excludedGameIds.Contains(g.Id))
                .CountAsync();

            var completedGames = await db.GameProgress
                .AsNoTracking()
                .Where(p => p.DateFinished.HasValue)
                .CountAsync();

            double percentage = 0;
            if (totalGames > 0)
            {
                percentage = ((double)completedGames / totalGames) * 100;
            }

            var newHash = $"{completedGames}:{totalGames}";

            if (newHash != lastDataHash)
            {
                lock (_stateLock)
                {
                    gamesCompletedCount = completedGames;
                    gamesInChallengeCount = totalGames;
                    percentageComplete = percentage;
                    lastDataHash = newHash;
                }
            }
        }
        catch (ObjectDisposedException)
        {
            // Component is being disposed, ignore
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading progress data: {ex.Message}");
            lock (_stateLock)
            {
                gamesCompletedCount = 0;
                gamesInChallengeCount = 0;
                percentageComplete = 0;
            }
            hasError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (isDisposed) return;
        
        isDisposed = true;
        
        if (hubConnection is not null)
        {
            try
            {
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error disposing SignalR connection: {ex.Message}");
            }
        }
    }
}
