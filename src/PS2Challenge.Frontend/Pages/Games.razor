@page "/games"
@using PS2Challenge.Backend.Models
@inject HttpClient Http

<PageTitle>All Games - PS2 Challenge</PageTitle>

<h1>PlayStation 2 Games</h1>

@if (games == null)
{
    <p><em>Loading games...</em></p>
}
else if (!games.Any())
{
    <p>No games found.</p>
}
else
{
    <div class="mb-3">
        <p>Total games: @games.Count() | Owned: @games.Count(g => g.IsOwned) | Excluded: @games.Count(g => g.IsExcluded)</p>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Developer</th>
                    <th>Publisher</th>
                    <th>Release Date</th>
                    <th>Region</th>
                    <th>Owned</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var game in games)
                {
                    <tr class="@GetRowClass(game)">
                        <td>@game.Title</td>
                        <td>@game.Developer</td>
                        <td>@game.Publisher</td>
                        <td>@(game.FirstReleased?.ToString("yyyy-MM-dd") ?? "Unknown")</td>
                        <td>@game.RegionFirstReleasedIn</td>
                        <td>
                            @if (game.IsExcluded)
                            {
                                <span class="badge bg-secondary">Excluded</span>
                            }
                            @if (game.IsOwned)
                            {
                                <span class="badge bg-success">Owned</span>
                            }
                            @if (!game.IsExcluded && !game.IsOwned)
                            {
                                <span class="badge bg-info">Available</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IEnumerable<GameDto>? games;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            games = await Http.GetFromJsonAsync<IEnumerable<GameDto>>("api/games");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading games: {ex.Message}");
        }
    }

    private string GetRowClass(GameDto game)
    {
        if (game.IsExcluded) return "table-secondary";
        if (game.IsOwned) return "table-success";
        return "";
    }
}